#--------------------------------------------------------------------
# ELStore GIS — .env
# Salin file ini ke ROOT project CI4 Anda (sejajar dengan folder app/)
# Rename dari .env.example menjadi .env
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# BASE URL — Sesuaikan dengan setup Anda
#--------------------------------------------------------------------

# Kalau pakai: php spark serve
# app.baseURL = 'http://localhost:8080/'

# Kalau pakai XAMPP / Apache (sesuaikan nama folder):
app.baseURL = http://localhost/elstore-gis/

# Kalau pakai domain sendiri:
# app.baseURL = 'https://elstore-gis.anda.com/'

app.indexPage = ''

#--------------------------------------------------------------------
# DATABASE — Sesuaikan dengan konfigurasi MySQL Anda
#--------------------------------------------------------------------
database.default.hostname = localhost
database.default.database = elstore_gis
database.default.username = root
database.default.password =

database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port     = 3306

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------
session.driver            = 'CodeIgniter\Session\Handlers\FileHandler'
session.cookieName        = 'elstore_session'
session.expiration        = 7200
# session.savePath          = null
session.matchIP           = false
session.timeToUpdate      = 300
session.regenerateDestroy = false

#--------------------------------------------------------------------
# ENCRYPTION KEY — Generate sekali pakai: php spark key:generate
#--------------------------------------------------------------------

encryption.key = hex2bin:bdcbc524b9d0a3ffe2c3d6ec7d0cdef42879c79c1ef6bd9c84b1913726dc8419


