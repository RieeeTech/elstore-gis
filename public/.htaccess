# ============================================================
#  ELStore GIS — public/.htaccess
#  Letakkan file ini di folder PUBLIC project CI4 Anda
# ============================================================

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /elstore-gis/

    # Jangan redirect untuk file/folder yang benar-benar ada
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Arahkan semua request ke index.php
    RewriteRule ^(.*)$ index.php/$1 [L]
</IfModule>

<IfModule !mod_rewrite.c>
    ErrorDocument 404 /index.php
</IfModule>

Options -Indexes
